# ── Single-key options (pick ONE, access all models) ──────────────

# OpenRouter (one key for ALL models — recommended for quickest setup)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Vercel AI Gateway (one key, routes to any provider)
# Get yours at https://vercel.com/dashboard → AI → Gateway
# VERCEL_AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1  # default, only set to override
VERCEL_AI_GATEWAY_API_KEY=
# Optional: second Vercel key for double throughput (round-robin, instant failover on 429)
VERCEL_AI_GATEWAY_API_KEY_2=

# Hugging Face (open-source models + your own fine-tunes)
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Direct provider keys (needed for "Direct APIs" and "AI SDK" modes) ──

# OpenAI (GPT-4o, GPT-4o-mini)
OPENAI_API_KEY=

# Anthropic (Claude Sonnet 4.6, Haiku 4.5, Agent SDK)
ANTHROPIC_API_KEY=

# Google (Gemini 2.5 Pro, Flash)
GOOGLE_API_KEY=

# DeepSeek (DeepSeek-R1)
DEEPSEEK_API_KEY=

# ── Local models ─────────────────────────────────────────────────

# Ollama (Llama, Qwen, etc.)
OLLAMA_BASE_URL=http://localhost:11434
